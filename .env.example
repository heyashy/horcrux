# Horcrux configuration — copy to .env and populate.
#
# Field naming: nested config uses double-underscore as the path delimiter.
# Example: QDRANT__PORT=6333 maps to settings.qdrant.port.
#
# See horcrux/config.py and ADR-0004 for the canonical schema.

# ── Required ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith tracing ─────────────────────────────────────────────
# Required if tracing is enabled (default: enabled).
LANGSMITH__API_KEY=ls__...
LANGSMITH__PROJECT=horcrux
LANGSMITH__TRACING_ENABLED=true

# ── Qdrant ────────────────────────────────────────────────────────
# Defaults match the docker-compose setup; override only if you change ports.
# QDRANT__HOST=localhost
# QDRANT__PORT=6333
# QDRANT__PARAGRAPHS_COLLECTION=hp_paragraphs
# QDRANT__CHAPTERS_COLLECTION=hp_chapters

# ── Temporal ──────────────────────────────────────────────────────
# Defaults match `temporal server start-dev` (in-process dev server).
# TEMPORAL__ADDRESS=localhost:7233
# TEMPORAL__NAMESPACE=default
# TEMPORAL__TASK_QUEUE=horcrux-ingest

# ── LiteLLM proxy ─────────────────────────────────────────────────
# Defaults match `litellm --config litellm_config.yaml --port 4000`.
# LITELLM__BASE_URL=http://localhost:4000
# LITELLM__HAIKU_ALIAS=haiku
# LITELLM__SONNET_ALIAS=sonnet

# ── Embedding ─────────────────────────────────────────────────────
# bge-large-en-v1.5 — open source, 1024-dim, asymmetric (query prefix required).
# EMBEDDING__MODEL_NAME=BAAI/bge-large-en-v1.5
# EMBEDDING__DIM=1024

# ── Paths ─────────────────────────────────────────────────────────
# CORPUS_PATH=data_lake/corpus.pdf
# CHECKPOINTER_DB=horcrux.db
